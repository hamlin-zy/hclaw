{
  "name": "hclaw",
  "version": "0.2.77",
  "description": "HClaw",
  "main": ".vite/main/index.js",
  "type": "commonjs",
  "author": "HClaw Team",
  "license": "MIT",
  "scripts": {
    "start": "node scripts/dev.js",
    "build": "vite build --config vite.main.config.mjs && vite build --config vite.preload.config.mjs && vite build --config vite.renderer.config.mjs",
    "build:prod": "node scripts/build-prod.js",
    "build:main": "vite build --config vite.main.config.mjs",
    "build:preload": "vite build --config vite.preload.config.mjs",
    "build:renderer": "vite build --config vite.renderer.config.mjs",
    "package": "npm run build:prod && node scripts/package.js",
    "make": "npm run build:prod && electron-builder --win",
    "make:mac": "npm run build:prod && electron-builder --mac",
    "#make:mac-arm64": "npm run build:prod && electron-builder --mac --arm64",
    "make:mac-x64": "npm run build:prod && electron-builder --mac --x64",
    "make:linux": "npm run build:prod && electron-builder --linux",
    "make:dir": "npm run build:prod && electron-builder --win --dir",
    "make:all": "npm run build:prod && electron-builder --win --mac --linux",
    "publish": "electron-builder --win --publish always",
    "lint": "eslint src --ext .ts,.tsx",
    "postinstall": "patch-package && echo 'Native modules handled by @photostructure/sqlite'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/generative-ai": "^0.24.1",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@photostructure/sqlite": "^1.2.1",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "diff": "^9.0.0",
    "framer-motion": "^12.0.0",
    "gray-matter": "^4.0.3",
    "iconv-lite": "^0.7.2",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "jschardet": "^3.1.4",
    "lucide-react": "^1.8.0",
    "openai": "^6.37.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.7",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@types/use-sync-external-store": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.17",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "config": {}
}
